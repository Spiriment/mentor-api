<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>
    <link
      href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        background-color: #F8F9FA;
        font-family: 'Poppins', Arial, sans-serif;
      }

      .email-wrapper {
        padding: 32px 16px;
        background-color: #F8F9FA;
      }

      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #FFFFFF;
        padding: 40px 32px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        color: #162419;
      }

      .logo-container {
        text-align: center;
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 2px solid #EBEEEC;
      }

      .logo-container img {
        max-width: 160px;
        width: auto;
        height: auto;
      }

      .content {
        font-size: 16px;
        line-height: 1.75;
        color: #162419;
      }

      .content h1,
      .content h2,
      .content h3 {
        color: #3A5A40;
        margin-top: 0;
      }

      .content p {
        margin: 0 0 16px 0;
      }

      .content a {
        color: #3A5A40;
        text-decoration: none;
        font-weight: 500;
      }

      .content a:hover {
        color: #162419;
        text-decoration: underline;
      }

      .button {
        display: inline-block;
        padding: 14px 32px;
        background-color: #3A5A40;
        color: #FFFFFF !important;
        text-decoration: none !important;
        border-radius: 8px;
        font-weight: 600;
        font-size: 15px;
        margin: 20px 0;
      }

      .button:hover {
        background-color: #162419;
      }

      .info-box {
        background-color: #EBEEEC;
        border-left: 4px solid #3A5A40;
        padding: 16px 20px;
        margin: 20px 0;
        border-radius: 4px;
      }

      .info-box strong {
        color: #3A5A40;
      }

      .footer {
        margin-top: 48px;
        text-align: center;
        padding-top: 24px;
      }

      .footer hr {
        border: none;
        border-top: 1px solid #C0CBC3;
        margin: 0 0 24px 0;
      }

      .support-text {
        font-size: 14px;
        color: #555;
        margin-bottom: 8px;
      }

      .support-link {
        color: #3A5A40;
        text-decoration: none;
        font-weight: 600;
      }

      .support-link:hover {
        color: #162419;
        text-decoration: underline;
      }

      .tagline {
        font-size: 13px;
        font-style: italic;
        color: #3A5A40;
        margin-top: 8px;
        font-weight: 500;
      }

      .copyright {
        font-size: 12px;
        color: #999999;
        margin-top: 6px;
      }

      @media (max-width: 520px) {
        .email-wrapper {
          padding: 16px 8px;
        }

        .email-container {
          padding: 24px 20px;
        }

        .button {
          padding: 12px 24px;
          font-size: 14px;
        }
      }
    </style>
  </head>
  <body>
    <div class='email-wrapper'>
      <div class='email-container'>
        <div class='logo-container'>
          <img src='cid:logo' alt='Spiriment' />
        </div>

        <div class='content'>
          {{{body}}}
        </div>

        <div class='footer'>
          <hr />
          <p class='support-text'>
            Need help? Contact
            <a href='mailto:support@spiriment.com' class='support-link'>support@spiriment.com</a>
            — we're here for you.
          </p>
          <p class='tagline'>Spiriment – Connect, Mentor, Grow</p>
          <p class='copyright'>© {{currentYear}} Spiriment. All rights reserved.</p>
        </div>
      </div>
    </div>
  </body>
</html>